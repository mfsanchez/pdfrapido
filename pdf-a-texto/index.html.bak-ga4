<body>

<nav>
    <div class="nav-inner">
        <a href="/" class="logo">
            <div class="logo-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg></div>
            <div class="logo-text">PDF<span>Rápido</span></div>
        </a>
        <a href="/" class="nav-back">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
            Todas las herramientas
        </a>
    </div>
</nav>

<main>
<nav aria-label="breadcrumb" style="max-width:800px;margin:0 auto;padding:20px 24px 16px;font-size:13px;color:var(--gray-400)">
    <ol style="list-style:none;padding:0;margin:0;display:flex;gap:8px;flex-wrap:wrap;align-items:center">
        <li><a href="/" style="color:var(--gray-400);text-decoration:none">Inicio</a></li>
        <li aria-hidden="true" style="color:var(--gray-300)">›</li>
        <li style="color:var(--gray-600);font-weight:500">PDF a Texto</li>
    </ol>
</nav>
<div class="tool-header">
        <div class="icon-badge">
            <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="#0D9488" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
                <line x1="8" y1="13" x2="16" y2="13"/>
                <line x1="8" y1="17" x2="14" y2="17"/>
            </svg>
        </div>
        <h1>PDF a Texto</h1>
        <p>Extrae el texto de tu PDF y descárgalo como .txt. Todo en tu navegador, sin subir archivos.</p>
    </div>

    <!-- Step 0: Upload -->
    <div class="upload-zone" id="uploadZone">
        <input type="file" accept=".pdf" id="fileInput" aria-label="Seleccionar archivo PDF">
        <div class="upload-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#0D9488" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
        </div>
        <h3>Arrastra tu PDF aquí o <span>selecciónalo</span></h3>
        <p>El texto se extrae directamente en tu navegador — tu archivo no se sube a ningún servidor</p>
    </div>

    <!-- Step 1: Progress -->
    <div class="step" id="stepProgress">
        <p class="progress-label" id="progressLabel">Analizando documento...</p>
        <div class="progress-wrap"><div class="progress-fill" id="progressFill"></div></div>
    </div>

    <!-- Step 2: Result -->
    <div class="step" id="stepResult">
        <div class="result-header">
            <span class="result-title" id="resultTitle">Texto extraído</span>
            <span class="result-meta" id="resultMeta"></span>
        </div>
        <textarea class="text-output" id="textOutput" spellcheck="false" aria-label="Texto extraído del PDF"></textarea>
        <div class="action-row">
            <button class="btn-primary" id="btnCopy" onclick="copyText()">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                Copiar texto
            </button>
            <button class="btn-secondary" onclick="downloadTxt()">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                Descargar .txt
            </button>
        </div>
        <button class="btn-reset" onclick="resetTool()">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/></svg>
            Extraer texto de otro PDF
        </button>
    </div>

    <!-- Step 3: Empty (scanned PDF) -->
    <div class="step" id="stepEmpty">
        <div class="empty-notice">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#9CA3AF" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="margin:0 auto 12px;display:block"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            <p style="font-weight:600;color:#4B5563;margin-bottom:6px">No se encontró texto en este PDF</p>
            <p style="color:#9CA3AF">El archivo parece ser un PDF escaneado (solo imagen). Para extraer texto de PDFs escaneados, usa la herramienta <a href="/ocr-a-pdf/" style="color:#0D9488">OCR a PDF</a>.</p>
        </div>
        <button class="btn-reset" onclick="resetTool()" style="margin-top:16px">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/></svg>
            Intentar con otro PDF
        </button>
    </div>

    <div class="ad-placeholder">Espacio publicitario — Google AdSense</div>

    <div class="seo-content">
        <h2>Cómo extraer texto de un PDF online</h2>
        <p>Arrastra tu PDF a la zona de carga o haz clic para seleccionarlo. La herramienta analiza todas las páginas del documento y extrae el texto manteniendo la estructura de párrafos.</p>
        <p>El resultado aparece en un área editable donde puedes revisar y modificar el texto antes de copiarlo o descargarlo. Todo el procesamiento ocurre en tu navegador gracias a PDF.js de Mozilla: tu archivo nunca llega a ningún servidor.</p>
        <p>Ideal para copiar contenido de informes, contratos, artículos o cualquier documento en formato PDF que tenga una capa de texto digital.</p>

        <div class="faq">
            <h2>Preguntas frecuentes</h2>
            <div class="faq-item">
                <p class="faq-q">¿Cómo extraer el texto de un PDF?</p>
                <p class="faq-a">Sube o arrastra tu PDF. El texto de todas las páginas se extrae automáticamente y aparece en un editor. Desde ahí puedes copiarlo al portapapeles o descargarlo como .txt con un solo clic.</p>
            </div>
            <div class="faq-item">
                <p class="faq-q">¿Mi archivo se sube a algún servidor?</p>
                <p class="faq-a">No. La extracción se hace 100% en tu navegador con PDF.js (Mozilla). Tu archivo nunca sale de tu dispositivo, lo que garantiza total privacidad.</p>
            </div>
            <div class="faq-item">
                <p class="faq-q">¿Funciona con PDFs escaneados?</p>
                <p class="faq-a">Esta herramienta extrae el texto digital ya embebido en el PDF. Si el documento es una imagen escaneada sin capa de texto, no habrá texto que extraer. Para esos casos, usa nuestra herramienta <a href="/ocr-a-pdf/" style="color:var(--accent)">OCR a PDF</a>.</p>
            </div>
            <div class="faq-item">
                <p class="faq-q">¿Se mantiene el formato del texto?</p>
                <p class="faq-a">Se preservan los saltos de párrafo y la separación entre bloques de texto. El formato visual (negritas, columnas, tablas) no puede transferirse a texto plano, ya que el formato .txt no admite estilos.</p>
            </div>
        </div>
    </div>

    <div class="related-tools">
        <h3>Herramientas relacionadas</h3>
        <ul>
            <li><a href="/ocr-a-pdf/">OCR a PDF</a></li>
            <li><a href="/pdf-a-word/">PDF a Word</a></li>
            <li><a href="/extraer-datos/">Extraer datos</a></li>
            <li><a href="/resumir-pdf/">Resumir PDF</a></li>
            <li><a href="/traducir-pdf/">Traducir PDF</a></li>
        </ul>
    </div>

<style>
.content-seo{max-width:800px;margin:48px auto 0;padding:0 24px 64px}
.content-seo h2{font-size:22px;font-weight:700;color:#1B2A4A;margin:40px 0 14px;letter-spacing:-.3px;border-bottom:2px solid #f3f4f6;padding-bottom:10px}
.content-seo h3{font-size:17px;font-weight:600;color:#374151;margin:20px 0 8px}
.content-seo p{font-size:15px;color:#4B5563;line-height:1.85;margin-bottom:14px}
.content-seo ul,.content-seo ol{padding-left:22px;margin-bottom:16px}
.content-seo li{font-size:15px;color:#4B5563;line-height:1.8;margin-bottom:6px}
.content-seo .steps{display:grid;gap:16px;margin:20px 0 28px}
.content-seo .step{display:flex;gap:16px;align-items:flex-start;background:#f9fafb;border-radius:12px;padding:18px 20px}
.content-seo .step-num{flex-shrink:0;width:36px;height:36px;border-radius:50%;background:#E8453C;color:#fff;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:15px}
.content-seo .step-body h3{margin:0 0 4px;font-size:15px;font-weight:600;color:#1B2A4A}
.content-seo .step-body p{margin:0;font-size:14px;color:#6B7280;line-height:1.6}
.content-seo .faq{display:grid;gap:12px;margin:20px 0}
.content-seo .faq-item{border:1px solid #e5e7eb;border-radius:10px;padding:18px 20px}
.content-seo .faq-item h3{font-size:15px;font-weight:600;color:#1B2A4A;margin:0 0 8px}
.content-seo .faq-item p{font-size:14px;color:#6B7280;line-height:1.7;margin:0}
.content-seo .use-cases{display:grid;gap:12px;margin:16px 0 24px}
.content-seo .use-case{background:#f9fafb;border-left:3px solid #E8453C;border-radius:0 10px 10px 0;padding:14px 18px}
.content-seo .use-case strong{display:block;font-size:14px;font-weight:600;color:#1B2A4A;margin-bottom:4px}
.content-seo .use-case span{font-size:14px;color:#6B7280;line-height:1.6}
</style>
<section class="content-seo" aria-label="Guía y preguntas frecuentes">
  <h2>¿Cómo funciona PDF a Texto?</h2>
  <p>Usar PDF a Texto en PDFRápido es un proceso sencillo que no requiere instalación ni registro. Sigue estos tres pasos:</p>
  <div class="steps">
      <div class="step">
        <div class="step-num">1</div>
        <div class="step-body">
          <h3>Carga el PDF</h3>
          <p>Sube el PDF del que quieres extraer el texto. Funciona con PDFs de texto nativo. Para PDFs escaneados, usa primero la herramienta de OCR.</p>
        </div>
      </div>
      <div class="step">
        <div class="step-num">2</div>
        <div class="step-body">
          <h3>Extracción del texto</h3>
          <p>La herramienta extrae todo el texto del PDF manteniendo la estructura de párrafos y secciones en la medida de lo posible.</p>
        </div>
      </div>
      <div class="step">
        <div class="step-num">3</div>
        <div class="step-body">
          <h3>Copia o descarga el texto</h3>
          <p>Obtén el texto extraído en formato .txt, listo para pegar en cualquier editor, procesador de texto o herramienta de IA.</p>
        </div>
      </div>
  </div>

  <h2>¿Cuándo usar esta herramienta?</h2>
  <p>La herramienta de PDF a Texto es útil en múltiples situaciones del día a día personal y profesional:</p>
  <div class="use-cases">
      <div class="use-case">
        <strong>Extraer texto para análisis con IA</strong>
        <span>Cuando quieres analizar, resumir o procesar el contenido de un PDF con herramientas de inteligencia artificial, necesitas primero extraer el texto en formato plano.</span>
      </div>
      <div class="use-case">
        <strong>Importar contenido a sistemas de gestión</strong>
        <span>Extrae el contenido de contratos, informes o documentos PDF para importarlo a bases de datos, wikis corporativas o sistemas de gestión documental.</span>
      </div>
      <div class="use-case">
        <strong>Comparar contenido de dos documentos</strong>
        <span>Extrae el texto de dos PDFs a formato .txt y usa cualquier herramienta de comparación de texto para detectar diferencias entre versiones del documento.</span>
      </div>
      <div class="use-case">
        <strong>Crear índices y búsquedas</strong>
        <span>Para sistemas de búsqueda documental, es necesario extraer el texto de los PDFs para indexarlo. Esta herramienta automatiza ese primer paso.</span>
      </div>
  </div>

  <h2>Preguntas frecuentes sobre PDF a Texto</h2>
  <div class="faq">
      <div class="faq-item">
        <h3>¿El texto extraído mantiene el formato original?</h3>
        <p>Se mantiene la estructura de párrafos básica, pero el formato visual como negritas, cursivas y tamaños de fuente se pierde al convertir a texto plano. Para preservar el formato, usa la conversión a Word en su lugar.</p>
      </div>
      <div class="faq-item">
        <h3>¿Funciona con PDFs protegidos contra copia?</h3>
        <p>Los PDFs con restricción de copia de texto no permiten la extracción directa. Primero deberías desbloquear el PDF con nuestra herramienta de desbloqueo y luego extraer el texto.</p>
      </div>
      <div class="faq-item">
        <h3>¿Se extraen los textos de las notas al pie y los encabezados?</h3>
        <p>Sí, se extrae todo el texto del PDF, incluyendo encabezados, pies de página, notas al pie, tablas y cuadros de texto. El orden puede variar con diseños de página complejos.</p>
      </div>
  </div>
</section>
</main>

<footer>
    <p>&copy; 2026 PDFRápido — dev: <a href="https://mfsanchez.com" target="_blank" rel="noopener">MF Sanchez</a> · <a href="/privacidad/">Privacidad</a> · <a href="/cookies/">Cookies</a> · <a href="/contacto/">Contacto</a> &nbsp;|&nbsp; <a href="/">Todas las herramientas</a></p>
</footer>

<script src="/js/pdf-3.11.min.js"></script>
<script>
pdfjsLib.GlobalWorkerOptions.workerSrc = '/js/pdf-3.11.worker.min.js';

let extractedText = '';
let originalName  = '';

// ── File input ──────────────────────────────────────────────────────────────
const fileInput  = document.getElementById('fileInput');
const uploadZone = document.getElementById('uploadZone');

fileInput.addEventListener('change', e => {
    const f = e.target.files[0];
    if (f) startExtraction(f);
});

// Drag-and-drop
uploadZone.addEventListener('dragover', e => { e.preventDefault(); uploadZone.classList.add('drag-over'); });
uploadZone.addEventListener('dragleave', () => uploadZone.classList.remove('drag-over'));
uploadZone.addEventListener('drop', e => {
    e.preventDefault();
    uploadZone.classList.remove('drag-over');
    const f = e.dataTransfer.files[0];
    if (f && f.type === 'application/pdf') startExtraction(f);
});

// ── Core extraction ──────────────────────────────────────────────────────────
async function startExtraction(file) {
    originalName = file.name.replace(/\.pdf$/i, '');
    uploadZone.style.display = 'none';
    showStep('stepProgress');

    const setProgress = (pct, label) => {
        document.getElementById('progressFill').style.width = pct + '%';
        document.getElementById('progressLabel').textContent = label;
    };

    try {
        setProgress(5, 'Cargando documento...');
        const bytes = await file.arrayBuffer();
        const pdf   = await pdfjsLib.getDocument({ data: bytes }).promise;
        const total = pdf.numPages;
        const pages = [];

        for (let i = 1; i <= total; i++) {
            setProgress(5 + Math.round((i / total) * 90), `Extrayendo texto — página ${i} de ${total}...`);
            const page    = await pdf.getPage(i);
            const content = await page.getTextContent();
            pages.push(buildPageText(content));
        }

        setProgress(100, 'Listo');
        extractedText = pages
            .map((t, i) => total > 1 ? `— Página ${i + 1} —\n\n${t}` : t)
            .join('\n\n');

        if (!extractedText.trim()) {
            showStep('stepEmpty');
            return;
        }

        const words = extractedText.trim().split(/\s+/).length;
        const chars = extractedText.trim().length;
        document.getElementById('resultTitle').textContent = `Texto extraído — ${total} ${total === 1 ? 'página' : 'páginas'}`;
        document.getElementById('resultMeta').textContent  = `${chars.toLocaleString('es')} caracteres · ${words.toLocaleString('es')} palabras`;
        document.getElementById('textOutput').value = extractedText;
        showStep('stepResult');

    } catch (err) {
        console.error(err);
        document.getElementById('progressLabel').textContent = 'Error al leer el PDF. ¿Es un PDF válido?';
    }
}

/**
 * Converts a pdf.js TextContent into a string preserving paragraph structure.
 * Strategy:
 *  - Items are sorted top-to-bottom (PDF y-axis is inverted).
 *  - Items on the same line (|Δy| < lineThreshold) are joined with a space.
 *  - A gap larger than paragraphThreshold between two lines inserts a blank line.
 */
function buildPageText(content) {
    const items = content.items;
    if (!items.length) return '';

    // Each item: { str, transform: [a,b,c,d,x,y], height, ... }
    // y in PDF coords (bottom-up); we negate to sort top-down.
    const lines = [];
    let currentLine = null;
    let prevY = null;

    // Sort top-to-bottom, left-to-right
    const sorted = [...items]
        .filter(it => it.str && it.str.trim() !== '')
        .sort((a, b) => {
            const yDiff = b.transform[5] - a.transform[5]; // descending y = top first
            return Math.abs(yDiff) < 2 ? a.transform[4] - b.transform[4] : yDiff;
        });

    for (const item of sorted) {
        const y    = item.transform[5];
        const text = item.str;

        if (prevY === null) {
            currentLine = [text];
            prevY = y;
            continue;
        }

        const dy = Math.abs(prevY - y);
        const lineHeight = item.height || 12;

        if (dy < lineHeight * 0.6) {
            // Same line — append with space (add only if needed)
            const last = currentLine[currentLine.length - 1];
            const sep  = (last.endsWith('-') || last.endsWith(' ') || text.startsWith(' ')) ? '' : ' ';
            currentLine.push(sep + text);
        } else {
            // New line — flush current
            lines.push({ text: currentLine.join(''), y: prevY });
            currentLine = [text];

            // Detect paragraph break: gap > 1.8× line height
            if (dy > lineHeight * 1.8 && lines.length > 0) {
                lines.push({ text: '', y: null }); // blank separator
            }
            prevY = y;
        }
    }
    if (currentLine) lines.push({ text: currentLine.join(''), y: prevY });

    // Collapse multiple blank lines into one, trim
    const result = lines
        .map(l => l.text)
        .join('\n')
        .replace(/\n{3,}/g, '\n\n')
        .trim();

    return result;
}

// ── Actions ──────────────────────────────────────────────────────────────────
function copyText() {
    const text = document.getElementById('textOutput').value;
    if (!text) return;
    navigator.clipboard.writeText(text).then(() => {
        const btn = document.getElementById('btnCopy');
        btn.classList.add('copied');
        btn.innerHTML = `<svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> ¡Copiado!`;
        setTimeout(() => {
            btn.classList.remove('copied');
            btn.innerHTML = `<svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg> Copiar texto`;
        }, 2200);
    }).catch(() => {
        // Fallback for browsers without clipboard API
        document.getElementById('textOutput').select();
        document.execCommand('copy');
    });
}

function downloadTxt() {
    const text = document.getElementById('textOutput').value;
    if (!text) return;
    const blob = new Blob([text], { type: 'text/plain;charset=utf-8' });
    const url  = URL.createObjectURL(blob);
    const a    = document.createElement('a');
    a.href     = url;
    a.download = (originalName || 'documento') + '.txt';
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
}

function resetTool() {
    extractedText = '';
    originalName  = '';
    fileInput.value = '';
    uploadZone.style.display = '';
    ['stepProgress', 'stepResult', 'stepEmpty'].forEach(id =>
        document.getElementById(id).classList.remove('active')
    );
    document.getElementById('progressFill').style.width = '0';
    document.getElementById('textOutput').value = '';
}

// ── Helpers ───────────────────────────────────────────────────────────────────
function showStep(id) {
    ['stepProgress', 'stepResult', 'stepEmpty'].forEach(s =>
        document.getElementById(s).classList.remove('active')
    );
    document.getElementById(id).classList.add('active');
}
</script>
<script src="/js/cookies-banner.js" defer></script>
<script src="/js/error-modal.js"></script>
</body>
</html>
