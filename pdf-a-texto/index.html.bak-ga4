    <style>
:root{--primary:#E8453C;--primary-light:#FFF0EF;--secondary:#1B2A4A;--accent:#0D9488;--accent-light:#CCFBF1;--accent-dark:#0F766E;--gray-50:#F9FAFB;--gray-100:#F3F4F6;--gray-200:#E5E7EB;--gray-300:#D1D5DB;--gray-400:#9CA3AF;--gray-500:#6B7280;--gray-600:#4B5563;--gray-700:#374151;--gray-800:#1F2937;--radius:12px;--radius-lg:16px;--radius-xl:24px;--shadow-sm:0 1px 2px rgba(0,0,0,.05);--shadow-lg:0 10px 25px -3px rgba(0,0,0,.08),0 4px 6px -4px rgba(0,0,0,.04)}
        *{margin:0;padding:0;box-sizing:border-box}
        body{font-family:'DM Sans',-apple-system,sans-serif;color:var(--gray-800);background:#fff;-webkit-font-smoothing:antialiased;min-height:100vh;display:flex;flex-direction:column}
        nav{position:fixed;top:0;width:100%;z-index:100;background:rgba(255,255,255,.92);backdrop-filter:blur(20px);border-bottom:1px solid var(--gray-200)}.nav-inner{max-width:1200px;margin:0 auto;padding:0 24px;height:64px;display:flex;align-items:center;justify-content:space-between}.logo{display:flex;align-items:center;gap:10px;text-decoration:none;color:var(--secondary)}.logo-icon{width:36px;height:36px;background:var(--primary);border-radius:8px;display:flex;align-items:center;justify-content:center}.logo-text{font-size:20px;font-weight:700;letter-spacing:-.5px}.logo-text span{color:var(--primary)}.nav-back{display:flex;align-items:center;gap:6px;text-decoration:none;color:var(--gray-500);font-size:14px;font-weight:500;transition:color .2s}.nav-back:hover{color:var(--primary)}
        main{flex:1;padding:104px 24px 60px;max-width:800px;margin:0 auto;width:100%}
        .tool-header{text-align:center;margin-bottom:36px}.tool-header .icon-badge{width:64px;height:64px;border-radius:16px;background:var(--accent-light);display:flex;align-items:center;justify-content:center;margin:0 auto 16px}.tool-header h1{font-size:32px;font-weight:700;color:var(--secondary);letter-spacing:-.8px;margin-bottom:8px}.tool-header p{font-size:16px;color:var(--gray-500)}
        .upload-zone{border:2px dashed var(--gray-300);border-radius:var(--radius-xl);padding:60px 40px;text-align:center;cursor:pointer;transition:all .3s;position:relative;background:var(--gray-50)}.upload-zone:hover,.upload-zone.drag-over{border-color:var(--accent);background:rgba(13,148,136,.04)}.upload-icon{width:72px;height:72px;border-radius:20px;background:var(--accent-light);display:flex;align-items:center;justify-content:center;margin:0 auto 20px;transition:transform .3s}.upload-zone:hover .upload-icon,.upload-zone.drag-over .upload-icon{transform:translateY(-4px)}.upload-zone h3{font-size:18px;font-weight:600;color:var(--secondary);margin-bottom:8px}.upload-zone h3 span{color:var(--accent)}.upload-zone p{font-size:14px;color:var(--gray-400)}.upload-zone input[type="file"]{position:absolute;inset:0;opacity:0;cursor:pointer}
        .step{display:none;animation:fadeInUp .4s ease-out}.step.active{display:block}
        .progress-wrap{background:var(--gray-100);border-radius:8px;height:8px;overflow:hidden;margin:20px 0 10px}.progress-fill{height:100%;background:var(--accent);border-radius:8px;transition:width .25s;width:0}.progress-label{text-align:center;font-size:14px;color:var(--gray-500);margin-bottom:8px}
        .result-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;flex-wrap:wrap;gap:10px}.result-title{font-size:15px;font-weight:600;color:var(--secondary)}.result-meta{font-size:13px;color:var(--gray-400)}
        .text-output{width:100%;min-height:360px;max-height:560px;padding:16px;border:1px solid var(--gray-200);border-radius:var(--radius);font-family:'DM Sans',-apple-system,sans-serif;font-size:14px;line-height:1.7;color:var(--gray-700);background:var(--gray-50);resize:vertical;outline:none;transition:border-color .2s}.text-output:focus{border-color:var(--accent);background:#fff}
        .action-row{display:flex;gap:12px;margin-top:16px;flex-wrap:wrap}
        .btn-primary{flex:1;min-width:160px;padding:13px 20px;border:none;border-radius:var(--radius);background:var(--accent);color:#fff;font-family:inherit;font-size:15px;font-weight:600;cursor:pointer;transition:all .25s;display:flex;align-items:center;justify-content:center;gap:8px}.btn-primary:hover{background:var(--accent-dark);transform:translateY(-1px);box-shadow:0 4px 14px rgba(13,148,136,.28)}.btn-primary.copied{background:#059669}
        .btn-secondary{flex:1;min-width:160px;padding:13px 20px;border:1px solid var(--gray-200);border-radius:var(--radius);background:#fff;color:var(--gray-700);font-family:inherit;font-size:15px;font-weight:500;cursor:pointer;transition:all .2s;display:flex;align-items:center;justify-content:center;gap:8px}.btn-secondary:hover{background:var(--gray-50);border-color:var(--accent);color:var(--accent)}
        .btn-reset{width:100%;margin-top:12px;padding:11px;border:none;border-radius:var(--radius);background:transparent;color:var(--gray-400);font-family:inherit;font-size:14px;cursor:pointer;transition:color .2s;display:flex;align-items:center;justify-content:center;gap:6px}.btn-reset:hover{color:var(--gray-600)}
        .empty-notice{padding:40px;text-align:center;color:var(--gray-400);font-size:14px;background:var(--gray-50);border:1px solid var(--gray-200);border-radius:var(--radius)}
        .seo-content{max-width:700px;margin:60px auto 0}.seo-content h2{font-size:22px;font-weight:700;color:var(--secondary);margin-bottom:14px}.seo-content p{font-size:15px;color:var(--gray-500);line-height:1.7;margin-bottom:12px}
        .faq{margin-top:40px}.faq h2{font-size:22px;font-weight:700;color:var(--secondary);margin-bottom:20px}.faq-item{border-bottom:1px solid var(--gray-200);padding:18px 0}.faq-item:last-child{border-bottom:none}.faq-q{font-size:15px;font-weight:600;color:var(--secondary);margin-bottom:8px}.faq-a{font-size:14px;color:var(--gray-500);line-height:1.7}
        .ad-placeholder{background:var(--gray-50);border:1px dashed var(--gray-300);border-radius:var(--radius);padding:16px;text-align:center;color:var(--gray-400);font-size:13px;margin-top:40px}
        footer{background:var(--secondary);color:#fff;padding:30px 24px;text-align:center;margin-top:auto}footer p{font-size:13px;color:rgba(255,255,255,.4)}footer a{color:rgba(255,255,255,.6);text-decoration:none}
        @keyframes fadeInUp{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
        @media(max-width:640px){main{padding:100px 16px 40px}.tool-header h1{font-size:26px}.upload-zone{padding:40px 20px}.action-row{flex-direction:column}.btn-primary,.btn-secondary{min-width:unset}}
    
        /* ── RELATED TOOLS ── */
        .related-tools {
            max-width: 700px;
            margin: 40px auto 0;
            padding: 28px;
            background: var(--gray-50);
            border-radius: var(--radius-lg);
            border: 1px solid var(--gray-200);
        }
        .related-tools h3 {
            font-size: 16px;
            font-weight: 600;
            color: var(--secondary);
            margin-bottom: 16px;
        }
        .related-tools ul {
            list-style: none;
            padding: 0;
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
        }
        .related-tools ul li a {
            display: inline-block;
            padding: 7px 16px;
            background: #fff;
            border: 1px solid var(--gray-200);
            border-radius: 100px;
            font-size: 14px;
            font-weight: 500;
            color: var(--secondary);
            text-decoration: none;
            transition: border-color 0.15s, color 0.15s;
        }
        .related-tools ul li a:hover {
            border-color: var(--primary);
            color: var(--primary);
        }

        </style>
