<script src="/js/convert.js" defer></script>
<script>
const ACTION = 'pdf-to-office';
const EXTRA_DATA = {"format":"xlsx"};
let resultBlob = null, resultFilename = '';

const uploadZone = document.getElementById('uploadZone');
const fileInput = document.getElementById('fileInput');

uploadZone.addEventListener('dragover', e => { e.preventDefault(); uploadZone.classList.add('dragover'); });
uploadZone.addEventListener('dragleave', () => uploadZone.classList.remove('dragover'));
uploadZone.addEventListener('drop', e => {
    e.preventDefault(); uploadZone.classList.remove('dragover');
    if (e.dataTransfer.files[0]) processFile(e.dataTransfer.files[0]);
});
fileInput.addEventListener('change', e => { if (e.target.files[0]) processFile(e.target.files[0]); });
document.getElementById('dlBtn').addEventListener('click', () => {
    if (resultBlob) downloadBlob(resultBlob, resultFilename);
});

async function processFile(file) {
    uploadZone.style.display = 'none';
    document.getElementById('errorMsg').classList.remove('show');
    document.getElementById('stepProgress').classList.add('active');
    document.getElementById('progressLabel').textContent = 'Subiendo y convirtiendo...';
    document.getElementById('progressBar').style.width = '0%';

    try {
        const result = await convertFile(file, ACTION, EXTRA_DATA, (pct, label) => {
            document.getElementById('progressLabel').textContent = label;
            document.getElementById('progressBar').style.width = pct + '%';
        });
        resultBlob = result.blob;
        resultFilename = result.filename;
        document.getElementById('resultDesc').textContent = `${result.filename} · ${formatSize(result.size)}`;
        document.getElementById('stepProgress').classList.remove('active');
        document.getElementById('resultArea').classList.add('active');
    } catch (err) {
        document.getElementById('stepProgress').classList.remove('active');
        document.getElementById('errorMsg').textContent = err.message;
        document.getElementById('errorMsg').classList.add('show');
        uploadZone.style.display = '';
    }
}

function reset() {
    resultBlob = null; resultFilename = '';
    fileInput.value = '';
    uploadZone.style.display = '';
    document.getElementById('errorMsg').classList.remove('show');
    ['stepProgress', 'resultArea'].forEach(id => document.getElementById(id).classList.remove('active'));
}
</script>
<script src="/js/cookies-banner.js" defer></script>
<script src="/js/error-modal.js"></script>
</body>
</html>
