:root{--primary:#E8453C;--primary-light:#FFF0EF;--secondary:#1B2A4A;--accent:#F5913E;--accent-light:#FFF3E0;--accent-dark:#D97A2B;--gray-50:#F9FAFB;--gray-100:#F3F4F6;--gray-200:#E5E7EB;--gray-300:#D1D5DB;--gray-400:#9CA3AF;--gray-500:#6B7280;--gray-600:#4B5563;--gray-700:#374151;--gray-800:#1F2937;--radius:12px;--radius-lg:16px;--radius-xl:24px;--shadow-sm:0 1px 2px rgba(0,0,0,.05);--shadow-lg:0 10px 25px -3px rgba(0,0,0,.08),0 4px 6px -4px rgba(0,0,0,.04)}
        *{margin:0;padding:0;box-sizing:border-box}body{font-family:'DM Sans',-apple-system,sans-serif;color:var(--gray-800);background:#fff;-webkit-font-smoothing:antialiased;min-height:100vh;display:flex;flex-direction:column}
        nav{position:fixed;top:0;width:100%;z-index:100;background:rgba(255,255,255,.92);backdrop-filter:blur(20px);border-bottom:1px solid var(--gray-200)}.nav-inner{max-width:1200px;margin:0 auto;padding:0 24px;height:64px;display:flex;align-items:center;justify-content:space-between}.logo{display:flex;align-items:center;gap:10px;text-decoration:none;color:var(--secondary)}.logo-icon{width:36px;height:36px;background:var(--primary);border-radius:8px;display:flex;align-items:center;justify-content:center}.logo-text{font-size:20px;font-weight:700;letter-spacing:-.5px}.logo-text span{color:var(--primary)}.nav-back{display:flex;align-items:center;gap:6px;text-decoration:none;color:var(--gray-500);font-size:14px;font-weight:500;transition:color .2s}.nav-back:hover{color:var(--primary)}
        main{flex:1;padding:104px 24px 60px;max-width:900px;margin:0 auto;width:100%}
        .tool-header{text-align:center;margin-bottom:36px}.tool-header .icon-badge{width:64px;height:64px;border-radius:16px;background:var(--accent-light);display:flex;align-items:center;justify-content:center;margin:0 auto 16px}.tool-header h1{font-size:32px;font-weight:700;color:var(--secondary);letter-spacing:-.8px;margin-bottom:8px}.tool-header p{font-size:16px;color:var(--gray-500)}
        .upload-zone{border:2px dashed var(--gray-300);border-radius:var(--radius-xl);padding:60px 40px;text-align:center;cursor:pointer;transition:all .3s;position:relative;background:var(--gray-50)}.upload-zone:hover{border-color:var(--accent)}.upload-icon{width:72px;height:72px;border-radius:20px;background:var(--accent-light);display:flex;align-items:center;justify-content:center;margin:0 auto 20px;transition:transform .3s}.upload-zone:hover .upload-icon{transform:translateY(-4px)}.upload-zone h3{font-size:18px;font-weight:600;color:var(--secondary);margin-bottom:8px}.upload-zone h3 span{color:var(--accent)}.upload-zone p{font-size:14px;color:var(--gray-400)}.upload-zone input[type="file"]{position:absolute;inset:0;opacity:0;cursor:pointer}
        .step{display:none;animation:fadeInUp .4s ease-out}.step.active{display:block}

        .quality-row{display:flex;align-items:center;gap:16px;margin-bottom:24px;background:var(--gray-50);border:1px solid var(--gray-200);border-radius:var(--radius);padding:16px 20px}
        .quality-row label{font-size:14px;font-weight:500;color:var(--gray-700);white-space:nowrap}
        .quality-row select{flex:1;padding:8px 12px;border:1px solid var(--gray-200);border-radius:8px;font-family:inherit;font-size:14px;outline:none;background:#fff}

        .action-btn{width:100%;padding:16px;border:none;border-radius:var(--radius);background:var(--accent);color:#fff;font-family:inherit;font-size:16px;font-weight:600;cursor:pointer;transition:all .25s;display:flex;align-items:center;justify-content:center;gap:10px}.action-btn:hover{background:var(--accent-dark);transform:translateY(-1px);box-shadow:0 4px 14px rgba(245,145,62,.3)}

        .progress-bar-wrap{margin:24px 0;background:var(--gray-100);border-radius:8px;height:8px;overflow:hidden}.progress-bar-fill{height:100%;background:var(--accent);border-radius:8px;transition:width .3s;width:0}
        .progress-text{text-align:center;font-size:14px;color:var(--gray-500);margin-bottom:16px}

        .images-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:16px;margin-bottom:24px}
        .img-thumb{border:1px solid var(--gray-200);border-radius:var(--radius);overflow:hidden;position:relative;cursor:pointer;transition:all .2s}
        .img-thumb:hover{box-shadow:var(--shadow-lg);transform:translateY(-2px)}
        .img-thumb img{width:100%;display:block}
        .img-thumb-label{position:absolute;bottom:0;left:0;right:0;padding:8px;background:linear-gradient(transparent,rgba(0,0,0,.6));color:#fff;font-size:12px;font-weight:500;text-align:center}
        .img-thumb-dl{position:absolute;top:8px;right:8px;width:28px;height:28px;border-radius:6px;background:rgba(255,255,255,.9);border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;opacity:0;transition:opacity .2s}
        .img-thumb:hover .img-thumb-dl{opacity:1}

        .dl-all-bar{display:flex;gap:12px;justify-content:center;flex-wrap:wrap;margin-bottom:20px}
        .btn-download{padding:14px 32px;border:none;border-radius:var(--radius);background:var(--accent);color:#fff;font-family:inherit;font-size:15px;font-weight:600;cursor:pointer;transition:all .25s;display:flex;align-items:center;gap:8px}.btn-download:hover{background:var(--accent-dark)}
        .btn-reset{padding:14px 24px;border:1px solid var(--gray-200);border-radius:var(--radius);background:#fff;color:var(--gray-600);font-family:inherit;font-size:15px;font-weight:500;cursor:pointer;transition:all .2s;display:flex;align-items:center;gap:8px}.btn-reset:hover{background:var(--gray-50)}

        .seo-content{max-width:700px;margin:60px auto 0}.seo-content h2{font-size:24px;font-weight:700;color:var(--secondary);margin-bottom:16px}.seo-content p{font-size:15px;color:var(--gray-500);line-height:1.7;margin-bottom:12px}
        .ad-placeholder{background:var(--gray-50);border:1px dashed var(--gray-300);border-radius:var(--radius);padding:16px;text-align:center;color:var(--gray-400);font-size:13px;margin-top:40px}
        footer{background:var(--secondary);color:#fff;padding:30px 24px;text-align:center;margin-top:auto}footer p{font-size:13px;color:rgba(255,255,255,.4)}footer a{color:rgba(255,255,255,.6);text-decoration:none}
        @keyframes fadeInUp{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
        @media(max-width:640px){main{padding:100px 16px 40px}.tool-header h1{font-size:26px}.upload-zone{padding:40px 24px}.images-grid{grid-template-columns:1fr 1fr}}
    
