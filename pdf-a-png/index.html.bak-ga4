<script src="/js/pdf-3.11.min.js"></script>
<script>
pdfjsLib.GlobalWorkerOptions.workerSrc = '/js/pdf-3.11.worker.min.js';

let images = [], originalName = '';

document.getElementById('fileInput').addEventListener('change', e => {
    const f = e.target.files[0]; if (!f) return;
    originalName = f.name.replace(/\.pdf$/i, '');
    document.getElementById('uploadZone').style.display = 'none';
    document.getElementById('stepConvert').classList.add('active');
});

const uploadZone = document.getElementById('uploadZone');
uploadZone.addEventListener('dragover', e => { e.preventDefault(); uploadZone.style.borderColor = 'var(--accent)'; });
uploadZone.addEventListener('dragleave', () => { uploadZone.style.borderColor = ''; });
uploadZone.addEventListener('drop', e => {
    e.preventDefault();
    uploadZone.style.borderColor = '';
    const f = e.dataTransfer.files[0];
    if (f && f.name.toLowerCase().endsWith('.pdf')) {
        originalName = f.name.replace(/\.pdf$/i, '');
        document.getElementById('fileInput')._droppedFile = f;
        uploadZone.style.display = 'none';
        document.getElementById('stepConvert').classList.add('active');
    }
});

async function convertPDF() {
    const input = document.getElementById('fileInput');
    const file = input._droppedFile || input.files[0];
    if (!file) return;
    images = [];

    document.getElementById('stepConvert').classList.remove('active');
    document.getElementById('stepProgress').classList.add('active');

    const scale = parseInt(document.getElementById('quality').value);
    const bytes = await file.arrayBuffer();
    const pdf = await pdfjsLib.getDocument({ data: bytes }).promise;
    const total = pdf.numPages;

    for (let i = 1; i <= total; i++) {
        document.getElementById('progressText').textContent = `Convirtiendo página ${i} de ${total}...`;
        document.getElementById('progressBar').style.width = ((i / total) * 100) + '%';

        const page = await pdf.getPage(i);
        const viewport = page.getViewport({ scale });
        const canvas = document.createElement('canvas');
        canvas.width = viewport.width;
        canvas.height = viewport.height;
        const ctx = canvas.getContext('2d');
        ctx.fillStyle = '#FFFFFF';
        ctx.fillRect(0, 0, canvas.width, canvas.height);
        await page.render({ canvasContext: ctx, viewport }).promise;

        const dataUrl = canvas.toDataURL('image/png');
        images.push({ dataUrl, name: `${originalName}_pagina_${i}.png` });
    }

    document.getElementById('stepProgress').classList.remove('active');
    document.getElementById('stepResult').classList.add('active');

    const grid = document.getElementById('imagesGrid');
    grid.innerHTML = '';
    images.forEach((img, i) => {
        const div = document.createElement('div');
        div.className = 'img-thumb';
        div.innerHTML = `<img src="${img.dataUrl}" alt="Página ${i + 1}"><div class="img-thumb-label">Página ${i + 1}</div><button class="img-thumb-dl" onclick="dlOne(${i})" title="Descargar"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#333" stroke-width="2.5" stroke-linecap="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg></button>`;
        grid.appendChild(div);
    });
}

function dlOne(i) {
    const a = document.createElement('a');
    a.href = images[i].dataUrl;
    a.download = images[i].name;
    document.body.appendChild(a); a.click(); document.body.removeChild(a);
}

function downloadAll() {
    images.forEach((img, i) => setTimeout(() => dlOne(i), i * 300));
}

function resetTool() {
    images = [];
    const input = document.getElementById('fileInput');
    input.value = '';
    input._droppedFile = null;
    document.getElementById('uploadZone').style.display = '';
    ['stepConvert', 'stepProgress', 'stepResult'].forEach(id => document.getElementById(id).classList.remove('active'));
    document.getElementById('progressBar').style.width = '0';
}
</script>
<script src="/js/cookies-banner.js" defer></script>
<script src="/js/error-modal.js"></script>
</body>
</html>
