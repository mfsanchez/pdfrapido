    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700&display=swap">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700&display=swap" media="print" onload="this.media='all'">
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700&display=swap"></noscript>
    <link rel="canonical" href="https://pdfrapido.eu/editar-metadatos-pdf/">
    <style>
:root {
    --primary: #E8453C; --primary-light: #FFF0EF;
    --secondary: #1B2A4A;
    --tool-color: #8E44AD; --tool-light: #F4ECF7; --tool-dark: #6C3483;
    --gray-50:#F9FAFB;--gray-100:#F3F4F6;--gray-200:#E5E7EB;--gray-300:#D1D5DB;
    --gray-400:#9CA3AF;--gray-500:#6B7280;--gray-600:#4B5563;--gray-700:#374151;
    --gray-800:#1F2937;
    --radius:12px;--radius-lg:16px;--radius-xl:24px;
    --shadow-sm:0 1px 2px rgba(0,0,0,.05);
    --shadow-lg:0 10px 25px -3px rgba(0,0,0,.08),0 4px 6px -4px rgba(0,0,0,.04);
}
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'DM Sans',-apple-system,sans-serif;color:var(--gray-800);background:#fff;-webkit-font-smoothing:antialiased;min-height:100vh;display:flex;flex-direction:column}
nav{position:fixed;top:0;width:100%;z-index:100;background:rgba(255,255,255,.92);backdrop-filter:blur(20px);border-bottom:1px solid var(--gray-200)}
.nav-inner{max-width:1200px;margin:0 auto;padding:0 24px;height:64px;display:flex;align-items:center;justify-content:space-between}
.logo{display:flex;align-items:center;gap:10px;text-decoration:none;color:var(--secondary)}
.logo-icon{width:36px;height:36px;background:var(--primary);border-radius:8px;display:flex;align-items:center;justify-content:center}
.logo-text{font-size:20px;font-weight:700;letter-spacing:-.5px}.logo-text span{color:var(--primary)}
.nav-back{display:flex;align-items:center;gap:6px;text-decoration:none;color:var(--gray-500);font-size:14px;font-weight:500;transition:color .2s}.nav-back:hover{color:var(--primary)}
main{flex:1;padding:104px 24px 60px;max-width:800px;margin:0 auto;width:100%}
.tool-header{text-align:center;margin-bottom:36px;animation:fadeIn .5s ease-out}
.tool-header .icon-badge{width:64px;height:64px;border-radius:16px;background:var(--tool-light);display:flex;align-items:center;justify-content:center;margin:0 auto 16px}
.tool-header h1{font-size:32px;font-weight:700;color:var(--secondary);letter-spacing:-.8px;margin-bottom:8px}
.tool-header p{font-size:16px;color:var(--gray-500);line-height:1.5}

/* Upload */
.upload-zone{border:2px dashed var(--gray-300);border-radius:var(--radius-xl);padding:60px 40px;text-align:center;cursor:pointer;transition:all .3s;position:relative;overflow:hidden;background:var(--gray-50);animation:fadeInUp .5s ease-out .1s both}
.upload-zone::before{content:'';position:absolute;inset:0;background:radial-gradient(circle at 50% 50%,rgba(142,68,173,.04),transparent 70%);pointer-events:none}
.upload-zone:hover,.upload-zone.dragover{border-color:var(--tool-color);background:rgba(142,68,173,.03);transform:scale(1.005)}
.upload-icon{width:72px;height:72px;border-radius:20px;background:var(--tool-light);display:flex;align-items:center;justify-content:center;margin:0 auto 20px;transition:transform .3s}
.upload-zone:hover .upload-icon{transform:translateY(-4px)}
.upload-zone h3{font-size:18px;font-weight:600;color:var(--secondary);margin-bottom:8px}
.upload-zone h3 span{color:var(--tool-color);text-decoration:underline;text-underline-offset:3px}
.upload-zone p{font-size:14px;color:var(--gray-400)}
.upload-zone input[type=file]{position:absolute;inset:0;opacity:0;cursor:pointer}

/* Process area */
.process-area{display:none;animation:fadeInUp .4s ease-out}
.process-area.active{display:block}

/* File card */
.file-card{background:#fff;border:1px solid var(--gray-200);border-radius:var(--radius-lg);padding:20px 24px;display:flex;align-items:center;gap:16px;margin-bottom:24px;box-shadow:var(--shadow-sm)}
.file-icon{width:48px;height:48px;border-radius:12px;background:var(--primary-light);display:flex;align-items:center;justify-content:center;flex-shrink:0}
.file-info{flex:1;min-width:0}
.file-info h4{font-size:15px;font-weight:600;color:var(--gray-800);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.file-info span{font-size:13px;color:var(--gray-400)}
.file-remove{width:36px;height:36px;border-radius:8px;border:1px solid var(--gray-200);background:#fff;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .2s;flex-shrink:0}
.file-remove:hover{background:var(--primary-light);border-color:var(--primary)}

/* Metadata form */
.meta-card{background:var(--gray-50);border:1px solid var(--gray-200);border-radius:var(--radius-lg);padding:24px;margin-bottom:24px}
.meta-card-title{font-size:14px;font-weight:700;color:var(--gray-700);margin-bottom:20px;display:flex;align-items:center;gap:8px}
.meta-card-title span{background:var(--tool-light);color:var(--tool-color);font-size:11px;font-weight:600;padding:2px 8px;border-radius:100px;text-transform:uppercase;letter-spacing:.4px}
.meta-row{display:grid;grid-template-columns:140px 1fr;align-items:start;gap:12px;margin-bottom:14px}
.meta-row:last-child{margin-bottom:0}
.meta-label{font-size:13px;font-weight:600;color:var(--gray-600);padding-top:10px;display:flex;flex-direction:column;gap:3px}
.meta-label small{font-size:11px;font-weight:400;color:var(--gray-400)}
.meta-input{width:100%;padding:9px 13px;border:1px solid var(--gray-200);border-radius:var(--radius);font-family:inherit;font-size:14px;color:var(--gray-800);background:#fff;transition:border-color .2s,box-shadow .2s;outline:none}
.meta-input:focus{border-color:var(--tool-color);box-shadow:0 0 0 3px rgba(142,68,173,.1)}
.meta-input::placeholder{color:var(--gray-300)}
.meta-readonly-val{display:block;padding:9px 13px;background:var(--gray-100);border:1px solid var(--gray-200);border-radius:var(--radius);font-size:13px;color:var(--gray-500);font-style:italic;min-height:38px}
.meta-divider{height:1px;background:var(--gray-200);margin:16px 0}
.readonly-label{color:var(--gray-400) !important}

/* Action buttons */
.action-row{display:grid;grid-template-columns:1fr auto;gap:12px;margin-bottom:0}
.btn-save{padding:15px 24px;border:none;border-radius:var(--radius);background:var(--tool-color);color:#fff;font-family:inherit;font-size:15px;font-weight:600;cursor:pointer;transition:all .25s;display:flex;align-items:center;justify-content:center;gap:9px}
.btn-save:hover:not(:disabled){background:var(--tool-dark);transform:translateY(-1px);box-shadow:0 4px 14px rgba(142,68,173,.35)}
.btn-save:disabled{opacity:.55;cursor:not-allowed;transform:none;box-shadow:none}
.btn-clear{padding:15px 20px;border:1px solid var(--gray-200);border-radius:var(--radius);background:#fff;color:var(--gray-600);font-family:inherit;font-size:14px;font-weight:500;cursor:pointer;transition:all .2s;display:flex;align-items:center;gap:8px;white-space:nowrap}
.btn-clear:hover{border-color:var(--primary);color:var(--primary);background:var(--primary-light)}

/* Progress */
.progress-area{display:none;text-align:center;padding:40px 0;animation:fadeIn .3s ease}
.progress-area.active{display:block}
.spinner{width:52px;height:52px;border:5px solid var(--gray-200);border-top-color:var(--tool-color);border-radius:50%;animation:spin .7s linear infinite;margin:0 auto 20px}
@keyframes spin{to{transform:rotate(360deg)}}
.progress-label{font-size:15px;color:var(--gray-500);font-weight:500}

/* Result */
.result-area{display:none;animation:fadeInUp .5s ease-out}
.result-area.active{display:block}
.result-card{background:#fff;border:1px solid var(--gray-200);border-radius:var(--radius-xl);padding:36px;text-align:center;box-shadow:var(--shadow-lg);position:relative;overflow:hidden}
.result-card::before{content:'';position:absolute;top:0;left:0;right:0;height:4px;background:linear-gradient(90deg,var(--tool-color),#C39BD3)}
.result-success-icon{width:64px;height:64px;border-radius:50%;background:var(--tool-light);display:flex;align-items:center;justify-content:center;margin:0 auto 16px;animation:scaleIn .4s cubic-bezier(.34,1.56,.64,1)}
@keyframes scaleIn{from{transform:scale(0);opacity:0}to{transform:scale(1);opacity:1}}
.result-card h3{font-size:22px;font-weight:700;color:var(--secondary);margin-bottom:8px}
.result-meta{font-size:14px;color:var(--gray-400);margin-bottom:28px}
.result-actions{display:flex;gap:12px;justify-content:center;flex-wrap:wrap}
.btn-download{padding:14px 28px;border:none;border-radius:var(--radius);background:var(--tool-color);color:#fff;font-family:inherit;font-size:15px;font-weight:600;cursor:pointer;transition:all .25s;display:flex;align-items:center;gap:8px}
.btn-download:hover{background:var(--tool-dark);transform:translateY(-1px);box-shadow:0 4px 14px rgba(142,68,173,.3)}
.btn-reset{padding:14px 20px;border:1px solid var(--gray-200);border-radius:var(--radius);background:#fff;color:var(--gray-600);font-family:inherit;font-size:15px;font-weight:500;cursor:pointer;transition:all .2s;display:flex;align-items:center;gap:8px}
.btn-reset:hover{background:var(--gray-50);border-color:var(--gray-300)}

/* SEO content */
.seo-content{max-width:700px;margin:60px auto 0;padding:0 4px}
.seo-content h2{font-size:24px;font-weight:700;color:var(--secondary);margin-bottom:16px;letter-spacing:-.5px}
.seo-content h3{font-size:18px;font-weight:600;color:var(--gray-700);margin:28px 0 10px}
.seo-content p{font-size:15px;color:var(--gray-500);line-height:1.7;margin-bottom:12px}
.seo-content ul{padding-left:20px;margin-bottom:12px}
.seo-content li{font-size:15px;color:var(--gray-500);line-height:1.7;margin-bottom:4px}
.related-tools{max-width:700px;margin:40px auto 0;padding:28px;background:var(--gray-50);border-radius:var(--radius-lg);border:1px solid var(--gray-200)}
.related-tools h3{font-size:16px;font-weight:600;color:var(--secondary);margin-bottom:16px}
.related-tools ul{list-style:none;padding:0;display:flex;flex-wrap:wrap;gap:10px}
.related-tools ul li a{display:inline-block;padding:7px 16px;background:#fff;border:1px solid var(--gray-200);border-radius:100px;font-size:14px;font-weight:500;color:var(--secondary);text-decoration:none;transition:border-color .15s,color .15s}
.related-tools ul li a:hover{border-color:var(--primary);color:var(--primary)}
footer{background:var(--secondary);color:#fff;padding:30px 24px;text-align:center;margin-top:auto}
footer p{font-size:13px;color:rgba(255,255,255,.4)}
footer a{color:rgba(255,255,255,.6);text-decoration:none}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
@keyframes fadeInUp{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}

/* content-seo section */
.content-seo{max-width:800px;margin:48px auto 0;padding:0 24px 64px}
.content-seo h2{font-size:22px;font-weight:700;color:#1B2A4A;margin:40px 0 14px;letter-spacing:-.3px;border-bottom:2px solid #f3f4f6;padding-bottom:10px}
.content-seo h3{font-size:17px;font-weight:600;color:#374151;margin:20px 0 8px}
.content-seo p{font-size:15px;color:#4B5563;line-height:1.85;margin-bottom:14px}
.content-seo ul{padding-left:22px;margin-bottom:16px}
.content-seo li{font-size:15px;color:#4B5563;line-height:1.8;margin-bottom:6px}
.content-seo .steps{display:grid;gap:16px;margin:20px 0 28px}
.content-seo .step{display:flex;gap:16px;align-items:flex-start;background:#f9fafb;border-radius:12px;padding:18px 20px}
.content-seo .step-num{flex-shrink:0;width:36px;height:36px;border-radius:50%;background:#8E44AD;color:#fff;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:15px}
.content-seo .step-body h3{margin:0 0 4px;font-size:15px;font-weight:600;color:#1B2A4A}
.content-seo .step-body p{margin:0;font-size:14px;color:#6B7280;line-height:1.6}
.content-seo .faq{display:grid;gap:12px;margin:20px 0}
.content-seo .faq-item{border:1px solid #e5e7eb;border-radius:10px;padding:18px 20px}
.content-seo .faq-item h3{font-size:15px;font-weight:600;color:#1B2A4A;margin:0 0 8px}
.content-seo .faq-item p{font-size:14px;color:#6B7280;line-height:1.7;margin:0}
.content-seo .use-cases{display:grid;gap:12px;margin:16px 0 24px}
.content-seo .use-case{background:#f9fafb;border-left:3px solid #8E44AD;border-radius:0 10px 10px 0;padding:14px 18px}
.content-seo .use-case strong{display:block;font-size:14px;font-weight:600;color:#1B2A4A;margin-bottom:4px}
.content-seo .use-case span{font-size:14px;color:#6B7280;line-height:1.6}

@media(max-width:640px){
    main{padding:100px 16px 40px}
    .tool-header h1{font-size:26px}
    .upload-zone{padding:40px 24px}
    .meta-row{grid-template-columns:1fr;gap:4px}
    .meta-label{padding-top:0}
    .action-row{grid-template-columns:1fr;grid-template-rows:auto auto}
    .result-card{padding:28px 20px}
}
