<body>

<nav>
  <div class="nav-inner">
    <a href="/" class="logo">
      <div class="logo-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg></div>
      <div class="logo-text">PDF<span>Rápido</span></div>
    </a>
    <a href="/" class="nav-back"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>Todas las herramientas</a>
  </div>
</nav>

<main>
<nav aria-label="breadcrumb" style="max-width:800px;margin:0 auto;padding:20px 24px 16px;font-size:13px;color:var(--gray-400)">
  <ol style="list-style:none;padding:0;margin:0;display:flex;gap:8px;flex-wrap:wrap;align-items:center">
    <li><a href="/" style="color:var(--gray-400);text-decoration:none">Inicio</a></li>
    <li aria-hidden="true" style="color:var(--gray-300)">›</li>
    <li style="color:var(--gray-600);font-weight:500">Editar metadatos PDF</li>
  </ol>
</nav>

<div class="tool-header">
  <div class="icon-badge">
    <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="#8E44AD" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
      <polyline points="14 2 14 8 20 8"/>
      <line x1="8" y1="13" x2="16" y2="13"/>
      <line x1="8" y1="17" x2="16" y2="17"/>
      <path d="M10 9H8"/>
    </svg>
  </div>
  <h1>Editar Metadatos PDF Online Gratis</h1>
  <p>Ve y edita el título, autor, asunto y más propiedades internas de tu PDF. Todo en tu navegador, sin subir el archivo a ningún servidor.</p>
</div>

<!-- UPLOAD -->
<div class="upload-zone" id="uploadZone">
  <input type="file" accept=".pdf,application/pdf" id="fileInput">
  <div class="upload-icon">
    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#8E44AD" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
      <polyline points="17 8 12 3 7 8"/>
      <line x1="12" y1="3" x2="12" y2="15"/>
    </svg>
  </div>
  <h3>Arrastra tu PDF aquí o <span>selecciónalo</span></h3>
  <p>Tamaño máximo: 100 MB · El archivo no se sube a ningún servidor</p>
</div>

<!-- PROCESS AREA -->
<div class="process-area" id="processArea">
  <!-- File card -->
  <div class="file-card">
    <div class="file-icon">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#E8453C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
    </div>
    <div class="file-info">
      <h4 id="fileName">documento.pdf</h4>
      <span id="fileSize">—</span>
    </div>
    <button class="file-remove" id="removeFile" title="Cambiar archivo">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--gray-400)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
  </div>

  <!-- Metadata form -->
  <div class="meta-card">
    <div class="meta-card-title">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#8E44AD" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      Metadatos del documento
      <span>editables</span>
    </div>

    <div class="meta-row">
      <label class="meta-label" for="metaTitle">Título<small>Title</small></label>
      <input class="meta-input" type="text" id="metaTitle" placeholder="(vacío)" maxlength="500">
    </div>
    <div class="meta-row">
      <label class="meta-label" for="metaAuthor">Autor<small>Author</small></label>
      <input class="meta-input" type="text" id="metaAuthor" placeholder="(vacío)" maxlength="500">
    </div>
    <div class="meta-row">
      <label class="meta-label" for="metaSubject">Asunto<small>Subject</small></label>
      <input class="meta-input" type="text" id="metaSubject" placeholder="(vacío)" maxlength="500">
    </div>
    <div class="meta-row">
      <label class="meta-label" for="metaKeywords">Palabras clave<small>Keywords · separar con comas</small></label>
      <input class="meta-input" type="text" id="metaKeywords" placeholder="(vacío)" maxlength="1000">
    </div>
    <div class="meta-row">
      <label class="meta-label" for="metaCreator">Creador<small>Creator</small></label>
      <input class="meta-input" type="text" id="metaCreator" placeholder="(vacío)" maxlength="500">
    </div>

    <div class="meta-divider"></div>

    <div class="meta-card-title" style="margin-bottom:16px;color:var(--gray-500)">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--gray-400)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
      <span style="background:var(--gray-100);color:var(--gray-500)">solo lectura</span>
      Solo lectura
    </div>

    <div class="meta-row">
      <label class="meta-label readonly-label">Productor<small>Producer</small></label>
      <span class="meta-readonly-val" id="metaProducer">—</span>
    </div>
    <div class="meta-row">
      <label class="meta-label readonly-label">Fecha creación<small>CreationDate</small></label>
      <span class="meta-readonly-val" id="metaCreationDate">—</span>
    </div>
    <div class="meta-row">
      <label class="meta-label readonly-label">Fecha modificación<small>ModDate</small></label>
      <span class="meta-readonly-val" id="metaModDate">—</span>
    </div>
  </div>

  <!-- Actions -->
  <div class="action-row">
    <button class="btn-save" id="saveBtn" onclick="saveMetadata()">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
      Guardar metadatos
    </button>
    <button class="btn-clear" id="clearBtn" onclick="clearMetadata()">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>
      Limpiar metadatos
    </button>
  </div>
</div>

<!-- PROGRESS -->
<div class="progress-area" id="progressArea">
  <div class="spinner"></div>
  <p class="progress-label" id="progressLabel">Procesando PDF...</p>
</div>

<!-- RESULT -->
<div class="result-area" id="resultArea">
  <div class="result-card">
    <div class="result-success-icon">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#8E44AD" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
    </div>
    <h3 id="resultTitle">PDF guardado correctamente</h3>
    <p class="result-meta" id="resultMeta">—</p>
    <div class="result-actions">
      <button class="btn-download" onclick="downloadResult()">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        Descargar PDF
      </button>
      <button class="btn-reset" onclick="resetTool()">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/></svg>
        Editar otro PDF
      </button>
    </div>
  </div>
</div>

<!-- AD -->
<div style="max-width:800px;margin:40px auto 0">
  <div style="background:var(--gray-50);border:1px dashed var(--gray-300);border-radius:var(--radius);padding:16px;text-align:center;color:var(--gray-400);font-size:13px">Espacio publicitario — Google AdSense</div>
</div>

<!-- SEO CONTENT -->
<div class="seo-content">
  <h2>¿Qué son los metadatos de un PDF y por qué editarlos?</h2>
  <p>Los metadatos son campos de información interna que todo archivo PDF lleva embebidos y que no forman parte del contenido visible del documento. Incluyen el título, el autor, el asunto, las palabras clave, el programa que lo creó y las fechas de creación y modificación. Cualquier visor de PDF puede mostrar estos datos: en Adobe Reader están en Archivo → Propiedades; en macOS basta con pulsar Cmd+I.</p>
  <p>Editar estos campos es útil en tres situaciones principales: <strong>personalización</strong> (añadir título y autor correctos a un documento), <strong>corrección</strong> (actualizar datos incorrectos generados automáticamente) y <strong>privacidad</strong> (eliminar información personal antes de compartir el PDF externamente).</p>

  <h3>Campos que puedes editar</h3>
  <ul>
    <li><strong>Título</strong> — el nombre del documento que aparece en la barra de título del visor y en los resultados de búsqueda.</li>
    <li><strong>Autor</strong> — la persona o entidad que creó el contenido. Puede revelar el nombre del empleado que redactó el documento.</li>
    <li><strong>Asunto</strong> — una descripción breve del contenido del PDF.</li>
    <li><strong>Palabras clave</strong> — términos que facilitan la búsqueda e indexación del documento.</li>
    <li><strong>Creador</strong> — el programa o sistema que generó el PDF original (Word, LibreOffice, LaTeX, etc.).</li>
  </ul>

  <h3>Privacidad: limpiar metadatos antes de compartir</h3>
  <p>El botón <em>Limpiar metadatos</em> elimina todos los campos editables del PDF de una sola vez. Esto es especialmente importante cuando compartes documentos fuera de tu organización: los metadatos pueden revelar nombres internos, herramientas corporativas o el historial de modificaciones.</p>
</div>

<div class="related-tools">
  <h3>Herramientas relacionadas</h3>
  <ul>
    <li><a href="/proteger-pdf/">Proteger PDF</a></li>
    <li><a href="/redactar-pdf/">Redactar PDF</a></li>
    <li><a href="/firmar-pdf/">Firmar PDF</a></li>
    <li><a href="/comprimir-pdf/">Comprimir PDF</a></li>
    <li><a href="/pdf-a-texto/">PDF a Texto</a></li>
  </ul>
</div>

<section class="content-seo" aria-label="Guía y preguntas frecuentes">
  <h2>¿Cómo funciona Editar Metadatos PDF?</h2>
  <p>La herramienta lee y escribe los metadatos del PDF directamente en tu navegador con pdf-lib. Tu archivo no se sube a ningún servidor en ningún momento.</p>
  <div class="steps">
    <div class="step">
      <div class="step-num">1</div>
      <div class="step-body"><h3>Sube tu PDF</h3><p>Arrastra el archivo o haz clic para seleccionarlo. Los metadatos actuales se cargan y muestran automáticamente en el formulario.</p></div>
    </div>
    <div class="step">
      <div class="step-num">2</div>
      <div class="step-body"><h3>Edita los campos</h3><p>Modifica título, autor, asunto, palabras clave y creador. Los campos en gris (productor, fechas) son de solo lectura.</p></div>
    </div>
    <div class="step">
      <div class="step-num">3</div>
      <div class="step-body"><h3>Descarga el PDF actualizado</h3><p>Pulsa "Guardar metadatos" para descargar el PDF con los nuevos valores, o "Limpiar metadatos" para eliminarlos todos.</p></div>
    </div>
  </div>

  <h2>¿Cuándo necesitas editar los metadatos de un PDF?</h2>
  <div class="use-cases">
    <div class="use-case"><strong>Privacidad al compartir documentos</strong><span>Los metadatos pueden revelar el nombre del redactor, la empresa o el software interno utilizado. Limpia los metadatos antes de enviar PDFs a clientes, proveedores o publicarlos en la web.</span></div>
    <div class="use-case"><strong>Documentos corporativos</strong><span>Estandariza el título y autor de todos los PDFs de tu empresa antes de distribuirlos. Mejora la organización y búsqueda interna de documentos.</span></div>
    <div class="use-case"><strong>Corrección de errores automáticos</strong><span>Muchos programas ponen el nombre del archivo o del perfil de Windows como autor automáticamente. Esta herramienta te permite corregirlo sin necesidad de regenerar el PDF.</span></div>
    <div class="use-case"><strong>SEO y archivos digitales</strong><span>Los motores de búsqueda leen los metadatos de los PDFs indexados. Un título y palabras clave correctos mejoran la visibilidad del documento en Google.</span></div>
  </div>

  <h2>Preguntas frecuentes sobre metadatos PDF</h2>
  <div class="faq">
    <div class="faq-item">
      <h3>¿Qué son los metadatos de un PDF?</h3>
      <p>Son campos de información interna embebidos en el archivo PDF que no forman parte del contenido visible. Incluyen título, autor, asunto, palabras clave, el programa que creó el documento y las fechas de creación y modificación. Cualquier visor de PDF puede consultarlos en las propiedades del documento.</p>
    </div>
    <div class="faq-item">
      <h3>¿Para qué sirve limpiar los metadatos?</h3>
      <p>Al compartir un PDF externamente los metadatos pueden revelar el nombre del autor original, el software corporativo utilizado o datos internos. Eliminarlos antes de enviar el documento protege la privacidad, especialmente en contextos legales, comerciales o cuando se publica en internet.</p>
    </div>
    <div class="faq-item">
      <h3>¿El PDF se sube a algún servidor?</h3>
      <p>No. Todo el procesamiento ocurre íntegramente en tu navegador mediante la librería open-source pdf-lib. Tu archivo no sale de tu dispositivo en ningún momento, lo que garantiza total privacidad incluso para documentos confidenciales.</p>
    </div>
  </div>
</section>
</main>

<footer>
  <p>&copy; 2026 PDFRápido — dev: <a href="https://mfsanchez.com" target="_blank" rel="noopener">MF Sanchez</a> · <a href="/privacidad/">Privacidad</a> · <a href="/cookies/">Cookies</a> · <a href="/contacto/">Contacto</a> &nbsp;|&nbsp; <a href="/">Todas las herramientas</a></p>
</footer>

<script src="/js/pdf-lib.min.js"></script>
<script>
// ── State ──
let originalFile = null;
let pdfDoc       = null;
let resultBlob   = null;

// ── DOM refs ──
const uploadZone  = document.getElementById('uploadZone');
const fileInput   = document.getElementById('fileInput');
const processArea = document.getElementById('processArea');
const progressArea= document.getElementById('progressArea');
const resultArea  = document.getElementById('resultArea');

// ── Drag & drop ──
uploadZone.addEventListener('dragover', e => { e.preventDefault(); uploadZone.classList.add('dragover'); });
uploadZone.addEventListener('dragleave', () => uploadZone.classList.remove('dragover'));
uploadZone.addEventListener('drop', e => {
    e.preventDefault(); uploadZone.classList.remove('dragover');
    const f = e.dataTransfer.files[0];
    if (f && f.type === 'application/pdf') handleFile(f);
    else alert('Por favor, selecciona un archivo PDF válido.');
});
fileInput.addEventListener('change', e => { if (e.target.files[0]) handleFile(e.target.files[0]); });
document.getElementById('removeFile').addEventListener('click', resetTool);

async function handleFile(file) {
    if (file.size > 100 * 1024 * 1024) { alert('El archivo supera el límite de 100 MB.'); return; }
    originalFile = file;
    document.getElementById('fileName').textContent = file.name;
    document.getElementById('fileSize').textContent  = formatSize(file.size);
    uploadZone.style.display = 'none';
    progressArea.classList.add('active');
    document.getElementById('progressLabel').textContent = 'Leyendo metadatos...';

    try {
        const bytes = await file.arrayBuffer();
        pdfDoc = await PDFLib.PDFDocument.load(bytes, { ignoreEncryption: true });
        loadMetadataFields();
        progressArea.classList.remove('active');
        processArea.classList.add('active');
    } catch(err) {
        progressArea.classList.remove('active');
        uploadZone.style.display = '';
        originalFile = null;
        alert('No se pudo leer el PDF. El archivo puede estar dañado o protegido con cifrado fuerte.');
    }
}

function loadMetadataFields() {
    const fill = (id, val) => {
        const el = document.getElementById(id);
        if (el.tagName === 'INPUT') el.value = val || '';
        else el.textContent = val || '(vacío)';
    };
    const fmtDate = d => {
        if (!d) return '(sin fecha)';
        try { return d.toLocaleString('es-ES', { day:'2-digit', month:'long', year:'numeric', hour:'2-digit', minute:'2-digit' }); }
        catch(e) { return d.toString(); }
    };
    fill('metaTitle',    pdfDoc.getTitle());
    fill('metaAuthor',   pdfDoc.getAuthor());
    fill('metaSubject',  pdfDoc.getSubject());
    fill('metaKeywords', pdfDoc.getKeywords());
    fill('metaCreator',  pdfDoc.getCreator());
    fill('metaProducer',     pdfDoc.getProducer() || '(vacío)');
    fill('metaCreationDate', fmtDate(pdfDoc.getCreationDate()));
    fill('metaModDate',      fmtDate(pdfDoc.getModificationDate()));
}

// ── Save metadata ──
async function saveMetadata() {
    if (!pdfDoc) return;
    await processPDF(false);
}

// ── Clear metadata ──
async function clearMetadata() {
    if (!pdfDoc) return;
    if (!confirm('¿Eliminar todos los metadatos del PDF? Esta acción no se puede deshacer en el archivo descargado.')) return;
    await processPDF(true);
}

async function processPDF(clearAll) {
    document.getElementById('saveBtn').disabled = true;
    document.getElementById('clearBtn').disabled = true;
    processArea.classList.remove('active');
    progressArea.classList.add('active');
    document.getElementById('progressLabel').textContent = clearAll ? 'Limpiando metadatos...' : 'Guardando metadatos...';
    await new Promise(r => setTimeout(r, 30));

    try {
        // Re-load fresh copy to avoid modifying cached doc
        const bytes = await originalFile.arrayBuffer();
        const freshDoc = await PDFLib.PDFDocument.load(bytes, { ignoreEncryption: true });

        if (clearAll) {
            freshDoc.setTitle('');
            freshDoc.setAuthor('');
            freshDoc.setSubject('');
            freshDoc.setKeywords([]);
            freshDoc.setCreator('');
            freshDoc.setProducer('');
        } else {
            const title    = document.getElementById('metaTitle').value.trim();
            const author   = document.getElementById('metaAuthor').value.trim();
            const subject  = document.getElementById('metaSubject').value.trim();
            const kwRaw    = document.getElementById('metaKeywords').value.trim();
            const creator  = document.getElementById('metaCreator').value.trim();

            freshDoc.setTitle(title);
            freshDoc.setAuthor(author);
            freshDoc.setSubject(subject);
            // Keywords: split by comma, trim each, filter empty
            const kws = kwRaw ? kwRaw.split(',').map(k => k.trim()).filter(Boolean) : [];
            freshDoc.setKeywords(kws);
            freshDoc.setCreator(creator);
        }

        // Update modification date
        freshDoc.setModificationDate(new Date());

        document.getElementById('progressLabel').textContent = 'Guardando PDF...';
        await new Promise(r => setTimeout(r, 10));
        const pdfBytes = await freshDoc.save();
        resultBlob = new Blob([pdfBytes], { type: 'application/pdf' });

        progressArea.classList.remove('active');
        resultArea.classList.add('active');

        const fieldsChanged = clearAll ? 'Todos los metadatos eliminados'
            : [
                document.getElementById('metaTitle').value   && 'Título',
                document.getElementById('metaAuthor').value  && 'Autor',
                document.getElementById('metaSubject').value && 'Asunto',
                document.getElementById('metaKeywords').value && 'Palabras clave',
                document.getElementById('metaCreator').value && 'Creador',
              ].filter(Boolean).join(', ') || 'Sin cambios en los campos';

        document.getElementById('resultTitle').textContent = clearAll
            ? 'Metadatos eliminados correctamente'
            : 'Metadatos guardados correctamente';
        document.getElementById('resultMeta').textContent = fieldsChanged + ' · ' + formatSize(pdfBytes.byteLength);

    } catch(err) {
        console.error(err);
        progressArea.classList.remove('active');
        processArea.classList.add('active');
        alert('Error al procesar el PDF: ' + (err.message || 'inténtalo de nuevo.'));
    } finally {
        document.getElementById('saveBtn').disabled = false;
        document.getElementById('clearBtn').disabled = false;
    }
}

function downloadResult() {
    if (!resultBlob) return;
    const url = URL.createObjectURL(resultBlob);
    const a   = document.createElement('a');
    a.href     = url;
    const base = originalFile.name.replace(/\.pdf$/i, '');
    a.download = base + '_metadatos.pdf';
    document.body.appendChild(a); a.click();
    document.body.removeChild(a); URL.revokeObjectURL(url);
}

function resetTool() {
    originalFile = null; pdfDoc = null; resultBlob = null;
    fileInput.value = '';
    uploadZone.style.display = '';
    processArea.classList.remove('active');
    progressArea.classList.remove('active');
    resultArea.classList.remove('active');
    ['metaTitle','metaAuthor','metaSubject','metaKeywords','metaCreator'].forEach(id => {
        document.getElementById(id).value = '';
    });
    document.getElementById('saveBtn').disabled = false;
    document.getElementById('clearBtn').disabled = false;
}

function formatSize(b) {
    if (b < 1024) return b + ' B';
    if (b < 1048576) return (b/1024).toFixed(1) + ' KB';
    return (b/1048576).toFixed(1) + ' MB';
}
</script>

<script src="/js/cookies-banner.js" defer></script>
<script src="/js/error-modal.js"></script>
</body>
</html>
