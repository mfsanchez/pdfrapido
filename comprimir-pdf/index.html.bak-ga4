<!-- PDF-LIB -->
<script src="/js/pdf-lib.min.js"></script>

<script>
    // State
    let originalFile = null;
    let compressedBlob = null;
    let compressionLevel = 'medium';

    // Elements
    const uploadZone = document.getElementById('uploadZone');
    const fileInput = document.getElementById('fileInput');
    const processArea = document.getElementById('processArea');
    const progressArea = document.getElementById('progressArea');
    const resultArea = document.getElementById('resultArea');

    // Drag & drop
    uploadZone.addEventListener('dragover', (e) => {
        e.preventDefault();
        uploadZone.classList.add('dragover');
    });
    uploadZone.addEventListener('dragleave', () => {
        uploadZone.classList.remove('dragover');
    });
    uploadZone.addEventListener('drop', (e) => {
        e.preventDefault();
        uploadZone.classList.remove('dragover');
        const file = e.dataTransfer.files[0];
        if (file && file.type === 'application/pdf') handleFile(file);
    });

    fileInput.addEventListener('change', (e) => {
        const file = e.target.files[0];
        if (file) handleFile(file);
    });

    document.getElementById('removeFile').addEventListener('click', resetTool);

    function handleFile(file) {
        if (file.size > 100 * 1024 * 1024) {
            alert('El archivo supera los 100 MB');
            return;
        }
        originalFile = file;
        document.getElementById('fileName').textContent = file.name;
        document.getElementById('fileSize').textContent = formatSize(file.size);

        uploadZone.style.display = 'none';
        processArea.classList.add('active');
        progressArea.classList.remove('active');
        resultArea.classList.remove('active');
    }

    function selectLevel(el) {
        document.querySelectorAll('.level-btn').forEach(b => b.classList.remove('selected'));
        el.classList.add('selected');
        compressionLevel = el.dataset.level;
    }

    function updateProgress(pct, label) {
        const circle = document.getElementById('progressCircle');
        const circumference = 2 * Math.PI * 44;
        circle.style.strokeDashoffset = circumference - (pct / 100) * circumference;
        document.getElementById('progressPct').textContent = Math.round(pct) + '%';
        if (label) document.getElementById('progressLabel').textContent = label;
    }

    async function compressPDF() {
        if (!originalFile) return;
        processArea.classList.remove('active');
        progressArea.classList.add('active');
        resultArea.classList.remove('active');
        updateProgress(0, 'Enviando archivo...');
        try {
            const formData = new FormData();
            formData.append('file', originalFile);
            formData.append('level', compressionLevel);
            updateProgress(30, 'Comprimiendo con Ghostscript...');
            const response = await fetch('/api/compress.php', {
                method: 'POST',
                body: formData
            });
            updateProgress(70, 'Procesando resultado...');
            const data = await response.json();
            if (data.error) throw new Error(data.error);
            updateProgress(100, 'Compresion completada');
            await new Promise(r => setTimeout(r, 400));
            const pdfBytes = Uint8Array.from(atob(data.pdf_base64), c => c.charCodeAt(0));
            compressedBlob = new Blob([pdfBytes], { type: 'application/pdf' });
            compressedFilename = data.filename;
            showResult(data.original_size, data.compressed_size);
        } catch (error) {
            console.error('Error:', error);
            alert('Error al procesar el PDF. El archivo podría estar protegido o dañado.');
            resetTool();
        }
    }

    function showResult(originalSize, compressedSize) {
        progressArea.classList.remove('active');
        resultArea.classList.add('active');

        // If compressed is actually bigger, use original
        if (compressedSize >= originalSize) {
            compressedBlob = originalFile;
            compressedSize = originalSize;
        }

        const origFormatted = formatSizeParts(originalSize);
        const compFormatted = formatSizeParts(compressedSize);
        const savingsPct = originalSize > 0 ? Math.round((1 - compressedSize / originalSize) * 100) : 0;

        document.getElementById('origSizeVal').textContent = origFormatted.val;
        document.getElementById('origSizeUnit').textContent = origFormatted.unit;
        document.getElementById('compSizeVal').textContent = compFormatted.val;
        document.getElementById('compSizeUnit').textContent = compFormatted.unit;
        const noSavings = savingsPct <= 0;
        document.getElementById('resultTitle').textContent = noSavings
            ? 'Este PDF no se puede comprimir más'
            : 'PDF comprimido correctamente';

        // Big savings counter
        const bigEl = document.getElementById('savingsBig');
        const bigNum = document.getElementById('savingsBigNum');
        bigEl.classList.toggle('no-savings', noSavings);
        if (noSavings) {
            bigNum.textContent = '0';
        } else {
            // Count-up animation
            let current = 0;
            const step = Math.ceil(savingsPct / 30);
            const timer = setInterval(() => {
                current = Math.min(current + step, savingsPct);
                bigNum.textContent = current;
                if (current >= savingsPct) clearInterval(timer);
            }, 30);
        }

        // Saved bytes text
        const savedBytes = originalSize - compressedSize;
        const amountEl = document.getElementById('savingsAmount');
        if (noSavings) {
            amountEl.textContent = 'El PDF ya está optimizado o es solo texto';
        } else {
            const s = formatSizeParts(savedBytes);
            amountEl.textContent = `Ahorraste ${s.val} ${s.unit}`;
        }

        // Badge
        document.getElementById('savingsPct').textContent = noSavings ? 'Sin reducción posible' : `${savingsPct}% reducido`;
        const badge = document.getElementById('savingsBadge');
        badge.style.background = noSavings ? 'var(--gray-100)' : savingsPct >= 30 ? '' : 'rgba(245,145,62,.12)';
        badge.style.color = noSavings ? 'var(--gray-500)' : savingsPct >= 30 ? '' : '#c07020';

        // Animate bars
        const ratio = originalSize > 0 ? (compressedSize / originalSize) * 100 : 100;
        setTimeout(() => {
            document.getElementById('barCompressed').style.width = Math.max(ratio, 5) + '%';
        }, 100);
    }

    function downloadPDF() {
        if (!compressedBlob) return;
        const url = URL.createObjectURL(compressedBlob);
        const a = document.createElement('a');
        a.href = url;
        const baseName = originalFile.name.replace(/\.pdf$/i, '');
        a.download = `${baseName}_comprimido.pdf`;
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        URL.revokeObjectURL(url);
    }

    function resetTool() {
        originalFile = null;
        compressedBlob = null;
        fileInput.value = '';

        uploadZone.style.display = '';
        processArea.classList.remove('active');
        progressArea.classList.remove('active');
        resultArea.classList.remove('active');

        // Reset progress
        updateProgress(0, 'Analizando PDF...');
        document.getElementById('barCompressed').style.width = '33%';
    }

    // Utilities
    function formatSize(bytes) {
        if (bytes < 1024) return bytes + ' B';
        if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
        return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
    }

    function formatSizeParts(bytes) {
        if (bytes < 1024) return { val: bytes.toString(), unit: 'B' };
        if (bytes < 1024 * 1024) return { val: (bytes / 1024).toFixed(1), unit: 'KB' };
        return { val: (bytes / (1024 * 1024)).toFixed(1), unit: 'MB' };
    }
</script>

<script src="/js/cookies-banner.js" defer></script>
<script src="/js/error-modal.js"></script>
</body>
</html>
