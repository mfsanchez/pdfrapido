<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Comprime PDF gratis y sin registro. Reduce el tamaño de tu PDF hasta un 80% sin perder calidad visible. Sin instalar nada, resultado en segundos.">
    <meta name="keywords" content="comprimir PDF, reducir tamaño PDF, comprimir PDF online gratis, optimizar PDF, PDF más pequeño">
    <meta name="author" content="MF Sanchez">
    <title>Comprimir PDF Online Gratis — Reduce el Tamaño | PDFRápido</title>
    <meta name="robots" content="index, follow, max-image-preview:large">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <link rel="apple-touch-icon" href="/favicon.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700&display=swap">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700&display=swap" media="print" onload="this.media='all'">
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700&display=swap"></noscript>    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>    <style>
:root {
            --primary: #E8453C;
            --primary-dark: #C73830;
            --primary-light: #FFF0EF;
            --secondary: #1B2A4A;
            --accent-green: #34A853;
            --accent-green-light: #E8F5E9;
            --accent-green-dark: #1E7E34;
            --gray-50: #F9FAFB;
            --gray-100: #F3F4F6;
            --gray-200: #E5E7EB;
            --gray-300: #D1D5DB;
            --gray-400: #9CA3AF;
            --gray-500: #6B7280;
            --gray-600: #4B5563;
            --gray-700: #374151;
            --gray-800: #1F2937;
            --gray-900: #111827;
            --radius: 12px;
            --radius-lg: 16px;
            --radius-xl: 24px;
            --shadow-sm: 0 1px 2px rgba(0,0,0,0.05);
            --shadow-md: 0 4px 6px -1px rgba(0,0,0,0.07), 0 2px 4px -2px rgba(0,0,0,0.05);
            --shadow-lg: 0 10px 25px -3px rgba(0,0,0,0.08), 0 4px 6px -4px rgba(0,0,0,0.04);
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'DM Sans', -apple-system, sans-serif;
            color: var(--gray-800);
            background: #fff;
            -webkit-font-smoothing: antialiased;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* ── NAV ── */
        nav {
            position: fixed;
            top: 0;
            width: 100%;
            z-index: 100;
            background: rgba(255,255,255,0.92);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--gray-200);
        }
        .nav-inner {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 24px;
            height: 64px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }
        .logo {
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
            color: var(--secondary);
        }
        .logo-icon {
            width: 36px;
            height: 36px;
            background: var(--primary);
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .logo-text {
            font-size: 20px;
            font-weight: 700;
            letter-spacing: -0.5px;
        }
        .logo-text span { color: var(--primary); }
        .nav-links {
            display: flex;
            gap: 32px;
            list-style: none;
        }
        .nav-links a {
            text-decoration: none;
            color: var(--gray-600);
            font-size: 14px;
            font-weight: 500;
            transition: color 0.2s;
        }
        .nav-links a:hover { color: var(--primary); }
        .nav-back {
            display: flex;
            align-items: center;
            gap: 6px;
            text-decoration: none;
            color: var(--gray-500);
            font-size: 14px;
            font-weight: 500;
            transition: color 0.2s;
        }
        .nav-back:hover { color: var(--primary); }

        /* ── MAIN ── */
        main {
            flex: 1;
            padding: 104px 24px 60px;
            max-width: 800px;
            margin: 0 auto;
            width: 100%;
        }

        /* ── TOOL HEADER ── */
        .tool-header {
            text-align: center;
            margin-bottom: 36px;
            animation: fadeIn 0.5s ease-out;
        }
        .tool-header .icon-badge {
            width: 64px;
            height: 64px;
            border-radius: 16px;
            background: var(--accent-green-light);
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 16px;
        }
        .tool-header h1 {
            font-size: 32px;
            font-weight: 700;
            color: var(--secondary);
            letter-spacing: -0.8px;
            margin-bottom: 8px;
        }
        .tool-header p {
            font-size: 16px;
            color: var(--gray-500);
            line-height: 1.5;
        }

        /* ── UPLOAD ZONE ── */
        .upload-zone {
            border: 2px dashed var(--gray-300);
            border-radius: var(--radius-xl);
            padding: 60px 40px;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
            background: var(--gray-50);
            animation: fadeInUp 0.5s ease-out 0.1s both;
        }
        .upload-zone::before {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(circle at 50% 50%, rgba(52,168,83,0.04), transparent 70%);
            pointer-events: none;
        }
        .upload-zone:hover, .upload-zone.dragover {
            border-color: var(--accent-green);
            background: rgba(52,168,83,0.03);
            transform: scale(1.005);
        }
        .upload-zone.dragover {
            border-color: var(--accent-green);
            background: rgba(52,168,83,0.06);
        }
        .upload-icon {
            width: 72px;
            height: 72px;
            border-radius: 20px;
            background: var(--accent-green-light);
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
            transition: transform 0.3s;
        }
        .upload-zone:hover .upload-icon {
            transform: translateY(-4px);
        }
        .upload-zone h3 {
            font-size: 18px;
            font-weight: 600;
            color: var(--secondary);
            margin-bottom: 8px;
        }
        .upload-zone h3 span {
            color: var(--accent-green);
            text-decoration: underline;
            text-underline-offset: 3px;
        }
        .upload-zone p {
            font-size: 14px;
            color: var(--gray-400);
        }
        .upload-zone input[type="file"] {
            position: absolute;
            inset: 0;
            opacity: 0;
            cursor: pointer;
        }

        /* ── PROCESSING AREA ── */
        .process-area {
            display: none;
            animation: fadeInUp 0.4s ease-out;
        }
        .process-area.active { display: block; }

        /* File info card */
        .file-card {
            background: #fff;
            border: 1px solid var(--gray-200);
            border-radius: var(--radius-lg);
            padding: 20px 24px;
            display: flex;
            align-items: center;
            gap: 16px;
            margin-bottom: 24px;
            box-shadow: var(--shadow-sm);
        }
        .file-icon {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            background: var(--primary-light);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }
        .file-info { flex: 1; min-width: 0; }
        .file-info h4 {
            font-size: 15px;
            font-weight: 600;
            color: var(--gray-800);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        .file-info span {
            font-size: 13px;
            color: var(--gray-400);
        }
        .file-remove {
            width: 36px;
            height: 36px;
            border-radius: 8px;
            border: 1px solid var(--gray-200);
            background: #fff;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.2s;
            flex-shrink: 0;
        }
        .file-remove:hover {
            background: var(--primary-light);
            border-color: var(--primary);
        }

        /* Compression options */
        .options-card {
            background: var(--gray-50);
            border: 1px solid var(--gray-200);
            border-radius: var(--radius-lg);
            padding: 24px;
            margin-bottom: 24px;
        }
        .options-card h4 {
            font-size: 14px;
            font-weight: 600;
            color: var(--gray-700);
            margin-bottom: 16px;
        }
        .compression-levels {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 10px;
        }
        .level-btn {
            border: 2px solid var(--gray-200);
            border-radius: var(--radius);
            padding: 16px 12px;
            text-align: center;
            cursor: pointer;
            transition: all 0.25s ease;
            background: #fff;
            position: relative;
        }
        .level-btn:hover {
            border-color: var(--accent-green);
            box-shadow: var(--shadow-sm);
        }
        .level-btn.selected {
            border-color: var(--accent-green);
            background: rgba(52,168,83,0.04);
        }
        .level-btn.selected::after {
            content: '';
            position: absolute;
            top: 8px;
            right: 8px;
            width: 8px;
            height: 8px;
            background: var(--accent-green);
            border-radius: 50%;
        }
        .level-btn .level-icon {
            font-size: 22px;
            margin-bottom: 6px;
        }
        .level-btn h5 {
            font-size: 13px;
            font-weight: 600;
            color: var(--gray-800);
            margin-bottom: 2px;
        }
        .level-btn span {
            font-size: 11px;
            color: var(--gray-400);
            line-height: 1.3;
            display: block;
        }

        /* Compress button */
        .compress-btn {
            width: 100%;
            padding: 16px;
            border: none;
            border-radius: var(--radius);
            background: var(--accent-green);
            color: #fff;
            font-family: inherit;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.25s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            letter-spacing: -0.2px;
        }
        .compress-btn:hover {
            background: var(--accent-green-dark);
            transform: translateY(-1px);
            box-shadow: 0 4px 14px rgba(52,168,83,0.3);
        }
        .compress-btn:active {
            transform: translateY(0);
        }
        .compress-btn:disabled {
            opacity: 0.6;
            cursor: not-allowed;
            transform: none;
            box-shadow: none;
        }

        /* ── PROGRESS ── */
        .progress-area {
            display: none;
            text-align: center;
            padding: 40px 0;
            animation: fadeIn 0.3s ease;
        }
        .progress-area.active { display: block; }
        .progress-ring {
            width: 100px;
            height: 100px;
            margin: 0 auto 20px;
            position: relative;
        }
        .progress-ring svg {
            transform: rotate(-90deg);
        }
        .progress-ring circle {
            fill: none;
            stroke-width: 6;
            stroke-linecap: round;
        }
        .progress-ring .bg { stroke: var(--gray-200); }
        .progress-ring .fg {
            stroke: var(--accent-green);
            transition: stroke-dashoffset 0.4s ease;
        }
        .progress-pct {
            position: absolute;
            inset: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            font-weight: 700;
            color: var(--secondary);
        }
        .progress-label {
            font-size: 15px;
            color: var(--gray-500);
            font-weight: 500;
        }

        /* ── RESULT ── */
        .result-area {
            display: none;
            animation: fadeInUp 0.5s ease-out;
        }
        .result-area.active { display: block; }

        .result-card {
            background: #fff;
            border: 1px solid var(--gray-200);
            border-radius: var(--radius-xl);
            padding: 36px;
            text-align: center;
            box-shadow: var(--shadow-lg);
            position: relative;
            overflow: hidden;
        }
        .result-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, var(--accent-green), #81C784);
        }

        .result-success-icon {
            width: 64px;
            height: 64px;
            border-radius: 50%;
            background: var(--accent-green-light);
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 16px;
            animation: scaleIn 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
        }
        @keyframes scaleIn {
            from { transform: scale(0); opacity: 0; }
            to { transform: scale(1); opacity: 1; }
        }
        .result-card h3 {
            font-size: 22px;
            font-weight: 700;
            color: var(--secondary);
            margin-bottom: 24px;
        }

        /* Big savings display */
        .savings-big{text-align:center;margin-bottom:4px;line-height:1}
        .savings-big-num{font-size:64px;font-weight:800;color:var(--accent-green);letter-spacing:-3px;font-variant-numeric:tabular-nums}
        .savings-big-pct{font-size:32px;font-weight:700;color:var(--accent-green);vertical-align:top;margin-top:12px;display:inline-block}
        .savings-big-label{display:block;font-size:13px;font-weight:500;color:var(--gray-400);text-transform:uppercase;letter-spacing:.5px;margin-top:2px}
        .savings-big.no-savings .savings-big-num,.savings-big.no-savings .savings-big-pct{color:var(--gray-300)}
        .savings-amount{text-align:center;font-size:14px;font-weight:500;color:var(--gray-500);margin-bottom:20px}

        /* Size comparison */
        .size-compare {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 20px;
            margin-bottom: 28px;
            flex-wrap: wrap;
        }
        .size-box {
            text-align: center;
            min-width: 120px;
        }
        .size-box label {
            display: block;
            font-size: 12px;
            color: var(--gray-400);
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 4px;
        }
        .size-box .size-val {
            font-size: 28px;
            font-weight: 700;
            letter-spacing: -1px;
        }
        .size-box .size-unit {
            font-size: 14px;
            font-weight: 500;
        }
        .size-box.original .size-val { color: var(--gray-400); }
        .size-box.compressed .size-val { color: var(--accent-green); }
        .size-arrow {
            color: var(--gray-300);
            font-size: 24px;
        }
        .savings-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: var(--accent-green-light);
            color: var(--accent-green-dark);
            padding: 8px 18px;
            border-radius: 100px;
            font-size: 14px;
            font-weight: 600;
            margin-bottom: 28px;
        }

        /* Visual bar */
        .size-bars {
            max-width: 400px;
            margin: 0 auto 28px;
        }
        .size-bar-row {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 8px;
        }
        .size-bar-label {
            width: 70px;
            font-size: 12px;
            color: var(--gray-400);
            text-align: right;
            flex-shrink: 0;
        }
        .size-bar-track {
            flex: 1;
            height: 12px;
            background: var(--gray-100);
            border-radius: 6px;
            overflow: hidden;
        }
        .size-bar-fill {
            height: 100%;
            border-radius: 6px;
            transition: width 0.8s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .size-bar-fill.original { background: var(--gray-300); }
        .size-bar-fill.compressed { background: var(--accent-green); }

        /* Buttons row */
        .result-actions {
            display: flex;
            gap: 12px;
            justify-content: center;
            flex-wrap: wrap;
        }
        .btn-download {
            padding: 14px 32px;
            border: none;
            border-radius: var(--radius);
            background: var(--accent-green);
            color: #fff;
            font-family: inherit;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.25s;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .btn-download:hover {
            background: var(--accent-green-dark);
            transform: translateY(-1px);
            box-shadow: 0 4px 14px rgba(52,168,83,0.3);
        }
        .btn-reset {
            padding: 14px 24px;
            border: 1px solid var(--gray-200);
            border-radius: var(--radius);
            background: #fff;
            color: var(--gray-600);
            font-family: inherit;
            font-size: 15px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .btn-reset:hover {
            background: var(--gray-50);
            border-color: var(--gray-300);
        }

        /* ── SEO CONTENT ── */
        .seo-content {
            max-width: 700px;
            margin: 60px auto 0;
            padding: 0 4px;
        }
        .seo-content h2 {
            font-size: 24px;
            font-weight: 700;
            color: var(--secondary);
            margin-bottom: 16px;
            letter-spacing: -0.5px;
        }
        .seo-content h3 {
            font-size: 18px;
            font-weight: 600;
            color: var(--gray-700);
            margin: 28px 0 10px;
        }
        .seo-content p {
            font-size: 15px;
            color: var(--gray-500);
            line-height: 1.7;
            margin-bottom: 12px;
        }
        .seo-content ul {
            padding-left: 20px;
            margin-bottom: 12px;
        }
        .seo-content li {
            font-size: 15px;
            color: var(--gray-500);
            line-height: 1.7;
            margin-bottom: 4px;
        }

        /* ── AD ── */
        .ad-container {
            max-width: 800px;
            margin: 40px auto;
            padding: 0 24px;
        }
        .ad-placeholder {
            background: var(--gray-50);
            border: 1px dashed var(--gray-300);
            border-radius: var(--radius);
            padding: 16px;
            text-align: center;
            color: var(--gray-400);
            font-size: 13px;
        }

        /* ── FOOTER ── */
        footer {
            background: var(--secondary);
            color: #fff;
            padding: 30px 24px;
            text-align: center;
            margin-top: auto;
        }
        footer p {
            font-size: 13px;
            color: rgba(255,255,255,0.4);
        }
        footer a {
            color: rgba(255,255,255,0.6);
            text-decoration: none;
        }

        /* ── ANIMATIONS ── */
        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }
        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(16px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* ── RESPONSIVE ── */
        @media (max-width: 640px) {
            .nav-links { display: none; }
            main { padding: 100px 16px 40px; }
            .tool-header h1 { font-size: 26px; }
            .upload-zone { padding: 40px 24px; }
            .compression-levels { grid-template-columns: 1fr; }
            .result-card { padding: 28px 20px; }
            .size-box .size-val { font-size: 22px; }
        }
    
        /* ── RELATED TOOLS ── */
        .related-tools {
            max-width: 700px;
            margin: 40px auto 0;
            padding: 28px;
            background: var(--gray-50);
            border-radius: var(--radius-lg);
            border: 1px solid var(--gray-200);
        }
        .related-tools h3 {
            font-size: 16px;
            font-weight: 600;
            color: var(--secondary);
            margin-bottom: 16px;
        }
        .related-tools ul {
            list-style: none;
            padding: 0;
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
        }
        .related-tools ul li a {
            display: inline-block;
            padding: 7px 16px;
            background: #fff;
            border: 1px solid var(--gray-200);
            border-radius: 100px;
            font-size: 14px;
            font-weight: 500;
            color: var(--secondary);
            text-decoration: none;
            transition: border-color 0.15s, color 0.15s;
        }
        .related-tools ul li a:hover {
            border-color: var(--primary);
            color: var(--primary);
        }

        </style>
<script async src="https://www.googletagmanager.com/gtag/js?id=G-93B5VKXW7W"></script>
